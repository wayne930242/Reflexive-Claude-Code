{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/hooks/validate_frontmatter.py\" 2>/dev/null || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/validate_frontmatter.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
