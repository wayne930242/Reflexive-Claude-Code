{
  "description": "Validate frontmatter and structure of SKILL.md, agent, and rule files after editing",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/validate_frontmatter.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
